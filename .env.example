# === Provider API Keys ===
# The agent uses the first available provider: Nvidia > Hugging Face > Ollama (local).

# NVIDIA API Key (Planner / Nemotron-3-Ultra)
# Get one at: https://build.nvidia.com/
NVIDIA_API_KEY=

# NVIDIA API Key (VLM / MiniMax-M3)
# If your VLM key is different from your planner key, put it here.
NVIDIA_VLM_API_KEY=
