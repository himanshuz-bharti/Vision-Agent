# === Provider API Keys ===
# The agent uses the first available provider: Groq > Hugging Face > Ollama (local).

# Groq API Key (RECOMMENDED - free tier: ~30 req/min, ~14,400 req/day)
# Get one free at: https://console.groq.com/keys
GROQ_API_KEY=

# Hugging Face API Token (free but very limited: ~100 req/month per model)
# Generate one at: https://huggingface.co/settings/tokens
HF_TOKEN=